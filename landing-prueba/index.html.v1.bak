<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Acelera — IA con sentido · concept v2</title>
  <meta name="description" content="Adopción de IA con sentido. Si la IA no suma, te lo decimos al inicio.">
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700;9..144,800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            paper:       '#F4EFE4',
            paperPure:   '#FBF7EE',
            ink:         '#0B0F14',
            inkDeep:     '#070A0E',
            accent:      '#C2410C',
            signal:      '#7A1F0E',
            yellow:      '#F1D98A',
            pink:        '#F1C3CE',
            cream:       '#EBDFB8',
            rust:        '#A33A1F'
          },
          fontFamily: {
            serif: ['Fraunces', 'ui-serif', 'Georgia', 'serif'],
            mono:  ['DM Mono', 'ui-monospace', 'SFMono-Regular', 'monospace'],
            sans:  ['Inter', 'ui-sans-serif', 'system-ui', 'sans-serif']
          },
          letterSpacing: {
            'extra-wide': '0.22em',
            'wider2':     '0.14em'
          }
        }
      }
    }
  </script>
  <style>
    body { background: #F4EFE4; color: #0B0F14; }
    .font-display { font-family: 'Fraunces', serif; font-feature-settings: 'liga' 1, 'ss01' 1; }

    /* Generative text-pattern fill: repeated words form a texture */
    .textpattern {
      background-image: var(--txt, none);
      background-clip: text;
      -webkit-background-clip: text;
      color: transparent;
      -webkit-text-fill-color: transparent;
      white-space: pre;
    }

    /* "Highlight" effect: a single word with a soft marker behind it */
    .mark {
      background-image: linear-gradient(180deg, transparent 55%, var(--mark, #F1D98A) 55%);
      padding: 0 0.12em;
      box-decoration-break: clone;
      -webkit-box-decoration-break: clone;
    }
    .mark--pink { --mark: #F1C3CE; }
    .mark--cream{ --mark: #EBDFB8; }
    .mark--ink  { --mark: #0B0F14; color: #F4EFE4; }

    /* Card with a soft outline like the reference */
    .card-outline {
      border: 1.25px solid #0B0F14;
      border-radius: 22px;
      background: transparent;
    }

    /* Old-paper grain */
    .grain {
      position: relative;
      isolation: isolate;
    }
    .grain::after {
      content: "";
      position: absolute;
      inset: 0;
      background-image:
        radial-gradient(rgba(0,0,0,0.06) 1px, transparent 1px),
        radial-gradient(rgba(255,255,255,0.04) 1px, transparent 1px);
      background-size: 3px 3px, 5px 5px;
      background-position: 0 0, 1px 2px;
      pointer-events: none;
      mix-blend-mode: multiply;
      opacity: .35;
      z-index: 1;
    }

    .skip-link:focus { transform: translateY(0) !important; }

    /* Editorial underline that feels marker-drawn */
    .markerline {
      background-image: linear-gradient(180deg, transparent 78%, var(--ml, #C2410C) 78%, var(--ml, #C2410C) 95%, transparent 95%);
    }
  </style>
</head>
<body class="font-sans antialiased">

  <a href="#section-1" class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-[999] focus:bg-ink focus:text-paper focus:px-4 focus:py-2 focus:rounded-md focus:font-medium focus:shadow-lg">Saltar al contenido</a>

  <header class="sticky top-0 z-40 backdrop-blur-md bg-paper/75 border-b border-ink/10">
    <div class="max-w-[1320px] mx-auto px-6 md:px-10 py-4 flex items-center justify-between gap-8">
      <a href="#section-1" class="font-display font-semibold text-2xl tracking-tight leading-none">
        <span class="relative inline-block">
          Acelera<span class="absolute left-0 right-0 -bottom-[0.18em] h-[2px] bg-accent"></span>
        </span>
      </a>
      <nav class="hidden md:flex items-center gap-10 font-mono text-sm uppercase tracking-wider2">
        <a href="#section-2" class="hover:text-accent transition-colors">Manifiesto</a>
        <a href="#section-3" class="hover:text-accent transition-colors">Capacidades</a>
        <a href="#section-4" class="hover:text-accent transition-colors">Proceso</a>
        <a href="#section-9" class="hover:text-accent transition-colors">Hablemos</a>
      </nav>
      <a href="#section-9" class="hidden md:inline-flex items-center gap-3 px-5 py-2.5 bg-ink text-paper rounded-full font-mono text-xs uppercase tracking-wider2">
        Empezar
        <span class="w-4 h-[2px] bg-accent"></span>
      </a>
    </div>
  </header>

  <main>

    <!-- ============================================================
         SECTION 1 — HERO
         Generative text-pattern fill on one side + H1 serif on the other
         ============================================================ -->
    <section id="section-1" data-section="hero" class="px-6 md:px-10 py-20 md:py-28 bg-paper relative">
      <div class="max-w-[1320px] mx-auto">
        <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">

          <div class="lg:col-span-8 order-1">

            <div class="flex items-center gap-4 mb-10">
              <span class="w-8 h-[2px] bg-ink/40"></span>
              <p class="font-mono text-[11px] uppercase tracking-extra-wide text-ink/70">Agencia de inteligencia artificial · Est. 2026 · Buenos Aires</p>
            </div>

            <h1 class="font-display font-semibold text-5xl sm:text-6xl md:text-7xl lg:text-8xl xl:text-9xl leading-[0.95] tracking-tight text-ink">
              IA <span class="mark">con sentido</span>,<br>
              donde el <span class="mark mark--pink">negocio</span><br>
              lo pide.
            </h1>

            <p class="mt-10 font-serif text-xl md:text-2xl text-ink/75 max-w-[560px] leading-snug">
              Implementamos IA donde el negocio la pide. Si no suma, te lo decimos al inicio.
            </p>

            <div class="mt-10 md:mt-12 flex flex-wrap items-center gap-6 md:gap-8">
              <a href="#section-9" class="inline-flex items-center gap-3 px-6 py-3.5 bg-ink text-paper rounded-full font-mono text-xs uppercase tracking-wider2 hover:bg-inkDeep transition-colors">
                Hablemos
                <span class="w-4 h-[2px] bg-accent"></span>
              </a>
              <a href="#section-2" class="font-serif text-lg md:text-xl text-ink markerline hover:text-accent transition-colors duration-200">
                Cómo trabajamos →
              </a>
            </div>
          </div>

          <aside aria-hidden="true" class="lg:col-span-4 order-2 mt-16 lg:mt-0 lg:pl-2">
            <div class="font-mono text-[9px] md:text-[10px] leading-[1.55] uppercase tracking-wider2 text-ink text-center select-none">
              <p class="opacity-25">SENTIDO · NEGOCIO · ADOPCIÓN · SENTIDO · NEGOCIO</p>
              <p class="opacity-40">NEGOCIO · ADOPCIÓN · SENTIDO · NEGOCIO · ADOPCIÓN</p>
              <p class="opacity-60">ADOPCIÓN · SENTIDO · NEGOCIO · SENTIDO · ADOPCIÓN</p>
              <p class="opacity-80">SENTIDO · NEGOCIO · ADOPCIÓN · SENTIDO · NEGOCIO</p>
              <p class="opacity-95">NEGOCIO · ADOPCIÓN · SENTIDO · NEGOCIO · ADOPCIÓN</p>
              <p class="opacity-100">ADOPCIÓN · SENTIDO · NEGOCIO · SENTIDO · ADOPCIÓN</p>
              <p class="opacity-95">SENTIDO · NEGOCIO · ADOPCIÓN · SENTIDO · NEGOCIO</p>
              <p class="opacity-75">NEGOCIO · ADOPCIÓN · SENTIDO · NEGOCIO · ADOPCIÓN</p>
              <p class="opacity-55">ADOPCIÓN · SENTIDO · NEGOCIO · SENTIDO · ADOPCIÓN</p>
              <p class="opacity-35">SENTIDO · NEGOCIO · ADOPCIÓN · SENTIDO · NEGOCIO</p>
              <p class="opacity-50">NEGOCIO · ADOPCIÓN · SENTIDO · NEGOCIO · ADOPCIÓN</p>
              <p class="opacity-65">ADOPCIÓN · SENTIDO · NEGOCIO · SENTIDO · ADOPCIÓN</p>
              <p class="opacity-85">SENTIDO · NEGOCIO · ADOPCIÓN · SENTIDO · NEGOCIO</p>
              <p class="opacity-90">NEGOCIO · ADOPCIÓN · SENTIDO · NEGOCIO · ADOPCIÓN</p>
              <p class="opacity-80">ADOPCIÓN · SENTIDO · NEGOCIO · SENTIDO · ADOPCIÓN</p>
              <p class="opacity-60">SENTIDO · NEGOCIO · ADOPCIÓN · SENTIDO · NEGOCIO</p>
              <p class="opacity-45">NEGOCIO · ADOPCIÓN · SENTIDO · NEGOCIO · ADOPCIÓN</p>
              <p class="opacity-30">ADOPCIÓN · SENTIDO · NEGOCIO · SENTIDO · ADOPCIÓN</p>
            </div>
          </aside>

        </div>
      </div>
    </section>

    <!-- ============================================================
         SECTION 2 — MANIFIESTO / DECLARACIÓN
         ============================================================ -->
    <section id="section-2" data-section="manifiesto" class="px-6 md:px-10 py-20 md:py-28 bg-inkDeep text-paper relative overflow-hidden">
      <div class="max-w-[1320px] mx-auto relative">

        <!-- Generative text-as-graphic backdrop: palabras repetidas a muy baja opacidad, sensación de página de libro -->
        <div aria-hidden="true" class="absolute inset-0 pointer-events-none select-none overflow-hidden">
          <p class="absolute top-2 -right-4 md:right-6 text-right max-w-full md:max-w-[680px] font-mono text-[10px] md:text-[11px] leading-[1.25] uppercase tracking-wider2 text-paper/[0.07]">
            PRIMERA REUNIÓN · PRIMERA REUNIÓN · PRIMERA REUNIÓN · PRIMERA REUNIÓN · PRIMERA REUNIÓN · PRIMERA REUNIÓN · PRIMERA REUNIÓN · PRIMERA REUNIÓN · PRIMERA REUNIÓN · PRIMERA REUNIÓN · PRIMERA REUNIÓN · PRIMERA REUNIÓN · PRIMERA REUNIÓN · PRIMERA REUNIÓN · PRIMERA REUNIÓN · PRIMERA REUNIÓN · PRIMERA REUNIÓN · PRIMERA REUNIÓN · PRIMERA REUNIÓN · PRIMERA REUNIÓN · PRIMERA REUNIÓN · PRIMERA REUNIÓN · PRIMERA REUNIÓN · PRIMERA REUNIÓN · PRIMERA REUNIÓN · PRIMERA REUNIÓN · PRIMERA REUNIÓN · PRIMERA REUNIÓN · PRIMERA REUNIÓN · PRIMERA REUNIÓN · PRIMERA REUNIÓN · PRIMERA REUNIÓN · PRIMERA REUNIÓN · PRIMERA REUNIÓN · PRIMERA REUNIÓN · PRIMERA REUNIÓN · PRIMERA REUNIÓN · PRIMERA REUNIÓN · PRIMERA REUNIÓN · PRIMERA REUNIÓN · PRIMERA REUNIÓN · PRIMERA REUNIÓN · PRIMERA REUNIÓN · PRIMERA REUNIÓN
          </p>
          <p class="absolute bottom-2 -left-4 md:left-6 max-w-full md:max-w-[560px] font-mono text-[10px] md:text-[11px] leading-[1.25] uppercase tracking-wider2 text-paper/[0.05]">
            PRODUCCIÓN · PRODUCCIÓN · PRODUCCIÓN · PRODUCCIÓN · PRODUCCIÓN · PRODUCCIÓN · PRODUCCIÓN · PRODUCCIÓN · PRODUCCIÓN · PRODUCCIÓN · PRODUCCIÓN · PRODUCCIÓN · PRODUCCIÓN · PRODUCCIÓN · PRODUCCIÓN · PRODUCCIÓN · PRODUCCIÓN · PRODUCCIÓN · PRODUCCIÓN · PRODUCCIÓN · PRODUCCIÓN · PRODUCCIÓN · PRODUCCIÓN · PRODUCCIÓN · PRODUCCIÓN · PRODUCCIÓN · PRODUCCIÓN · PRODUCCIÓN · PRODUCCIÓN · PRODUCCIÓN · PRODUCCIÓN · PRODUCCIÓN · PRODUCCIÓN · PRODUCCIÓN · PRODUCCIÓN · PRODUCCIÓN · PRODUCCIÓN · PRODUCCIÓN
          </p>
        </div>

        <!-- Foreground content -->
        <div class="relative z-10">

          <!-- Eyebrow editorial con meta a la derecha -->
          <div class="flex items-baseline gap-4 mb-12 md:mb-16">
            <span class="font-mono text-[11px] uppercase tracking-extra-wide text-accent">No. 01 — Manifiesto</span>
            <span class="hidden sm:inline-block flex-1 h-px bg-paper/15 translate-y-[-3px]"></span>
            <span class="hidden sm:inline-block font-mono text-[11px] uppercase tracking-extra-wide text-paper/40">Carácter · Acelera</span>
          </div>

          <!-- H2 ENORME — declaración fuerte -->
          <h2 class="font-display font-semibold text-[44px] sm:text-[60px] md:text-[80px] lg:text-[104px] xl:text-[120px] leading-[0.92] tracking-[-0.025em] max-w-[16ch] mb-14 md:mb-20">
            Te decimos cuándo <span class="markerline">no</span>.
          </h2>

          <!-- Cuerpo: 2 párrafos a la izquierda + reframe a la derecha con border-accent -->
          <div class="grid md:grid-cols-12 gap-10 md:gap-x-14 md:gap-y-2 max-w-[1100px]">
            <div class="md:col-span-7 space-y-6">
              <p class="font-display text-[19px] md:text-[22px] leading-[1.5] text-paper/85">
                Si tu proceso no necesita IA, lo decimos en la primera reunión. <span class="text-paper">Perdemos el proyecto y ganamos el próximo.</span>
              </p>
              <p class="font-display text-[19px] md:text-[22px] leading-[1.5] text-paper/85">
                Si la necesita, no nos vamos hasta que esté en producción y tu equipo sepa operarla. <span class="text-paper">No queremos dejarte una caja negra que solo nosotros sepamos tocar.</span>
              </p>
            </div>
            <div class="md:col-span-4 md:col-start-9 md:pt-1">
              <div class="border-l border-accent/70 pl-5 md:pl-6">
                <p class="font-display text-[22px] md:text-[27px] leading-[1.2] text-paper font-semibold tracking-[-0.01em]">
                  Adoptar IA cambia cómo decide y opera el negocio. <span class="text-accent">La herramienta es apenas el arranque.</span>
                </p>
              </div>
            </div>
          </div>

          <!-- Firma mono accent -->
          <div class="mt-16 md:mt-24 flex items-center gap-4">
            <span class="w-10 h-px bg-accent"></span>
            <p class="font-mono text-[11px] uppercase tracking-extra-wide text-accent">— A eso venimos.</p>
          </div>

        </div>

      </div>
    </section>

    <!-- ============================================================
         SECTION 3 — CAPACIDADES (3-4 servicios)
         ============================================================ -->
    <section id="section-3" data-section="capacidades" class="px-6 md:px-10 py-20 md:py-28 bg-paper">
      <div class="max-w-[1320px] mx-auto">

        <!-- Header: eyebrow + H2 a la izquierda, descriptor editorial a la derecha -->
        <header class="flex flex-col gap-8 md:flex-row md:items-end md:justify-between mb-10 md:mb-14">
          <div class="max-w-[26ch]">
            <p class="font-mono text-xs uppercase tracking-extra-wide text-accent mb-6">01 — Capacidades</p>
            <h2 class="font-serif font-medium text-4xl md:text-5xl lg:text-[3.75rem] leading-[1.02] tracking-[-0.01em]">
              Lo que entregamos, <span class="mark mark--yellow">donde lo necesitás.</span>
            </h2>
          </div>
          <p class="font-mono text-xs uppercase tracking-wider2 text-ink/60 md:max-w-[22ch] md:text-right leading-relaxed">
            Tres servicios.<br>Una sola promesa: que funcione.
          </p>
        </header>

        <!-- Generative text-pattern: verbos repetidos con opacidades variables -->
        <div class="font-mono uppercase tracking-extra-wide text-[10px] sm:text-xs leading-[2] overflow-hidden mb-14 md:mb-20 select-none" aria-hidden="true">
          <p class="whitespace-nowrap">
            <span class="text-ink/40">Medir</span> <span class="text-ink/15">·</span> <span class="text-ink/25">Construir</span> <span class="text-ink/15">·</span> <span class="text-ink/45">Transferir</span> <span class="text-ink/15">·</span> <span class="text-ink/20">Medir</span> <span class="text-ink/15">·</span> <span class="text-ink/35">Construir</span> <span class="text-ink/15">·</span> <span class="text-ink/30">Transferir</span> <span class="text-ink/15">·</span> <span class="text-ink/40">Medir</span> <span class="text-ink/15">·</span> <span class="text-ink/25">Construir</span> <span class="text-ink/15">·</span> <span class="text-ink/45">Transferir</span> <span class="text-ink/15">·</span> <span class="text-ink/20">Medir</span> <span class="text-ink/15">·</span> <span class="text-ink/35">Construir</span> <span class="text-ink/15">·</span> <span class="text-ink/30">Transferir</span> <span class="text-ink/15">·</span>
          </p>
          <p class="whitespace-nowrap">
            <span class="text-ink/25">Construir</span> <span class="text-ink/15">·</span> <span class="text-ink/40">Transferir</span> <span class="text-ink/15">·</span> <span class="text-ink/20">Medir</span> <span class="text-ink/15">·</span> <span class="text-ink/35">Construir</span> <span class="text-ink/15">·</span> <span class="text-ink/45">Transferir</span> <span class="text-ink/15">·</span> <span class="text-ink/30">Medir</span> <span class="text-ink/15">·</span> <span class="text-ink/25">Construir</span> <span class="text-ink/15">·</span> <span class="text-ink/40">Transferir</span> <span class="text-ink/15">·</span> <span class="text-ink/20">Medir</span> <span class="text-ink/15">·</span> <span class="text-ink/35">Construir</span> <span class="text-ink/15">·</span> <span class="text-ink/45">Transferir</span> <span class="text-ink/15">·</span>
          </p>
        </div>

        <!-- Grid de 3 capacidades -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">

          <!-- 01 — Diagnóstico -->
          <article class="card-outline p-8 md:p-10 flex flex-col gap-8">
            <div class="flex items-start justify-between gap-4">
              <span class="font-mono text-7xl font-medium text-ink/15 leading-none tracking-[-0.02em]">01</span>
              <span class="font-mono text-[10px] uppercase tracking-extra-wide text-ink/60 mt-4">— Medir</span>
            </div>
            <div>
              <h3 class="font-serif font-semibold text-2xl md:text-[1.7rem] leading-[1.1] tracking-[-0.01em] mb-4">
                Diagnóstico honesto.
              </h3>
              <p class="text-[0.95rem] leading-relaxed text-ink/70">
                Vemos con datos si la IA conviene. Procesos, números, decisiones. Si no aplica, te lo decimos al inicio.
              </p>
            </div>
          </article>

          <!-- 02 — Implementación -->
          <article class="card-outline p-8 md:p-10 flex flex-col gap-8">
            <div class="flex items-start justify-between gap-4">
              <span class="font-mono text-7xl font-medium text-ink/15 leading-none tracking-[-0.02em]">02</span>
              <span class="font-mono text-[10px] uppercase tracking-extra-wide text-ink/60 mt-4">— Construir</span>
            </div>
            <div>
              <h3 class="font-serif font-semibold text-2xl md:text-[1.7rem] leading-[1.1] tracking-[-0.01em] mb-4">
                Implementación a medida.
              </h3>
              <p class="text-[0.95rem] leading-relaxed text-ink/70">
                Construimos sobre tu infraestructura. Producción en semanas, no en meses. Sin reemplazar lo que funciona.
              </p>
            </div>
          </article>

          <!-- 03 — Transferencia -->
          <article class="card-outline p-8 md:p-10 flex flex-col gap-8">
            <div class="flex items-start justify-between gap-4">
              <span class="font-mono text-7xl font-medium text-ink/15 leading-none tracking-[-0.02em]">03</span>
              <span class="font-mono text-[10px] uppercase tracking-extra-wide text-ink/60 mt-4">— Transferir</span>
            </div>
            <div>
              <h3 class="font-serif font-semibold text-2xl md:text-[1.7rem] leading-[1.1] tracking-[-0.01em] mb-4">
                Tu equipo al mando.
              </h3>
              <p class="text-[0.95rem] leading-relaxed text-ink/70">
                Tu equipo opera. Código, documentación y capacitación para que no dependas de nosotros cuando nos vayamos.
              </p>
            </div>
          </article>

        </div>

      </div>
    </section>

    <!-- ============================================================
         SECTION 4 — PROCESO (3 pasos)
         ============================================================ -->
    <section id="section-4" data-section="proceso" class="px-6 md:px-10 py-20 md:py-28 bg-paperPure">
      <div class="max-w-[1320px] mx-auto">

        <!-- Header -->
        <div class="max-w-3xl">
          <p class="font-mono text-xs uppercase tracking-extra-wide text-accent mb-6">02 — Cómo lo hacemos</p>
          <h2 class="font-display font-semibold text-4xl md:text-6xl leading-[0.98] tracking-tight">
            Tres pasos.<br>
            <span class="mark">Sin</span> saltos, sin demos eternas.
          </h2>
          <p class="mt-6 font-sans text-base md:text-lg text-ink/70 max-w-xl leading-relaxed">
            Trabajamos en ciclos cortos. De la primera charla a algo que funciona en producción — y que tu equipo sabe sostener sin nosotros.
          </p>
        </div>

        <!-- 3 phases -->
        <div class="mt-16 md:mt-20 border-t border-ink/15 grid grid-cols-1 md:grid-cols-3">

          <!-- Phase 01 -->
          <div class="relative overflow-hidden py-10 md:py-12 md:pr-10 border-b md:border-b-0 md:border-r border-ink/15">
            <div aria-hidden="true" class="pointer-events-none absolute -top-2 right-2 md:right-6 font-mono leading-[0.85] text-right select-none">
              <div class="text-[11px] tracking-widest">
                <span class="text-ink/[0.20]">01</span> <span class="text-ink/[0.14]">01</span> <span class="text-ink/[0.10]">01</span><br>
                <span class="text-ink/[0.14]">01</span> <span class="text-ink/[0.10]">01</span> <span class="text-ink/[0.07]">01</span><br>
                <span class="text-ink/[0.10]">01</span> <span class="text-ink/[0.07]">01</span> <span class="text-ink/[0.05]">01</span><br>
                <span class="text-ink/[0.07]">01</span> <span class="text-ink/[0.05]">01</span> <span class="text-ink/[0.04]">01</span>
              </div>
            </div>
            <div class="relative">
              <div class="font-display font-semibold text-7xl md:text-8xl leading-none text-ink/15 select-none">01</div>
